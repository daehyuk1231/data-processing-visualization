   "source": [
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 이미지 읽기\n",
    "image = cv2.imread(\"../images/photo1.jpg\")\n",
    "\n",
    "# OpenCV는 BGR 형식으로 이미지를 읽기 때문에, \n",
    "# 맷플롯립에서 올바르게 표시하려면 RGB로 변환해야 함\n",
    "image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n",
    "\n",
    "# 이미지 표시\n",
    "plt.imshow(image)\n",
    "plt.show()  "
   ]
  }
